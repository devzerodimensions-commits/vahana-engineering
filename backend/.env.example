# Copy this file to ".env" and fill in your own values.

# Server
PORT=5000
NODE_ENV=development

# Frontend origin allowed by CORS
CLIENT_URL=http://localhost:5173

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/vihana_engineering
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/vihana_engineering?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/vihana_engineering

# JSON Web Token
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=7d

# Default admin account created by the seed script (npm run seed)
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@vihaanaengineering.com
ADMIN_PASSWORD=Admin@12345
